# =====================================================================
#  KAYAD PLATFORM — Environment Variables
#  Copy to .env for local dev; set in Vercel/Render for production
# =====================================================================

# ─── PLATFORM IDENTITY ───────────────────────────────────────────────
VITE_PLATFORM_NAME="KAYAD"
VITE_DOMAIN="kayad.space"
VITE_WEBHOST_EMAIL="owner@kayad.space"

# ── API ───────────────────────────────────────────────────────────────
# In dev, Vite's proxy forwards /api → backend (see vite.config.js)
# In production, Vercel rewrites /api → Render backend (see vercel.json)
# DO NOT set VITE_API_BASE_URL — the code uses '/api' directly
VITE_SOCKET_URL=https://kayad-backend.onrender.com

# ── APP ───────────────────────────────────────────────────────────────
VITE_APP_NAME=Kayad
VITE_APP_VERSION=2.0.0

# ── FEATURE FLAGS ────────────────────────────────────────────────────
VITE_ENABLE_CHAT=true
VITE_ENABLE_ESCROW=true
VITE_ENABLE_AUCTIONS=true
VITE_ENABLE_COMPARE=true
VITE_ENABLE_REVIEWS=true

# ── SENTRY ────────────────────────────────────────────────[OPTIONAL]
VITE_SENTRY_DSN=
VITE_SENTRY_TRACE_RATE=0.1

# ── GOOGLE ANALYTICS ──────────────────────────────────────[OPTIONAL]
VITE_GA_MEASUREMENT_ID=

# ── GOOGLE MAPS ───────────────────────────────────────────[OPTIONAL]
VITE_GOOGLE_MAPS_KEY=

# =====================================================================
#  BACKEND — See backend/.env.example for all server-side vars
#  These are NOT used by the frontend build; set in your hosting
#  platform (Render/Railway) or copy backend/.env.example → backend/.env
# =====================================================================
# Required backend vars (set in deployment environment):
#   MONGO_URI, JWT_SECRET, MPESA_CONSUMER_KEY, CLOUDINARY_CLOUD_NAME, etc.
# See backend/.env.example for the complete list.
