# =====================================================================
#  KAYAD FRONTEND — Environment Variables
#  Copy to .env — all VITE_ vars are exposed to the browser
# =====================================================================

# ── API ───────────────────────────────────────────────────────────────
# In dev, Vite's proxy forwards /api → backend (see vite.config.js)
# In production, set this to your actual backend domain
VITE_API_BASE_URL=https://kayad.space
VITE_SOCKET_URL=https://kayad-backend.onrender.com

# ── APP ───────────────────────────────────────────────────────────────
VITE_APP_NAME=Kayad
VITE_APP_VERSION=2.0.0

# ── SENTRY ────────────────────────────────────────────────[OPTIONAL]
# 1. sentry.io → New Project → React
# 2. Copy DSN here → error tracking activates automatically
VITE_SENTRY_DSN=
VITE_SENTRY_TRACE_RATE=0.1

# ── GOOGLE ANALYTICS ──────────────────────────────────────[OPTIONAL]
# 1. analytics.google.com → Create property → Web
# 2. Copy Measurement ID (G-XXXXXXXXXX) here
VITE_GA_MEASUREMENT_ID=

# ── GOOGLE MAPS ───────────────────────────────────────────[OPTIONAL]
# For car location map preview on listing page
VITE_GOOGLE_MAPS_KEY=

# ── FEATURE FLAGS ────────────────────────────────────────────────────
VITE_ENABLE_CHAT=true
VITE_ENABLE_ESCROW=true
VITE_ENABLE_AUCTIONS=true
VITE_ENABLE_COMPARE=true
VITE_ENABLE_REVIEWS=true
