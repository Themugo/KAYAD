# =====================================================================
#  KAYAD PLATFORM — Environment Variables
#  Copy to .env for local dev; set in Vercel/Render for production
# =====================================================================

# ─── PLATFORM IDENTITY ───────────────────────────────────────────────
VITE_PLATFORM_NAME="KAYAD"
VITE_DOMAIN="kayad.space"
VITE_WEBHOST_EMAIL="jimmythemugo@gmail.com"

# ── API ───────────────────────────────────────────────────────────────
# In dev, Vite's proxy forwards /api → backend (see vite.config.js)
# In production, set this to your actual backend domain
VITE_API_BASE_URL=https://kayad.space
VITE_SOCKET_URL=https://kayad-backend.onrender.com

# ── APP ───────────────────────────────────────────────────────────────
VITE_APP_NAME=Kayad
VITE_APP_VERSION=2.0.0

# ── FEATURE FLAGS ────────────────────────────────────────────────────
VITE_ENABLE_CHAT=true
VITE_ENABLE_ESCROW=true
VITE_ENABLE_AUCTIONS=true
VITE_ENABLE_COMPARE=true
VITE_ENABLE_REVIEWS=true

# ── SENTRY ────────────────────────────────────────────────[OPTIONAL]
VITE_SENTRY_DSN=
VITE_SENTRY_TRACE_RATE=0.1

# ── GOOGLE ANALYTICS ──────────────────────────────────────[OPTIONAL]
VITE_GA_MEASUREMENT_ID=

# ── GOOGLE MAPS ───────────────────────────────────────────[OPTIONAL]
VITE_GOOGLE_MAPS_KEY=

# =====================================================================
#  BACKEND — Required for server deployment (set in Render/Vercel)
# =====================================================================

# ── DATABASE ──────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/kayad
MONGO_POOL_SIZE=10

# ── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here
ACCESS_TOKEN_EXPIRE=1h
REFRESH_TOKEN_EXPIRE=7d

# ── MPESA DARAJA ───────────────────────────────────────────────────────
MPESA_ENV=production
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://kayad-backend.onrender.com/api/payments/callback
MPESA_SKIP_IP_CHECK=false
KAYAD_MASTER_PAYBILL=174379
MPESA_EXTRA_IPS=

# ── REDIS ────────────────────────────────────────────────────────────[OPTIONAL]
REDIS_URL=redis://default:password@host:port

# ── MEDIA STORAGE ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── EXTERNAL ───────────────────────────────────────────────────────────
APP_NAME=Kayad
APP_VERSION=2.0.0
FRONTEND_URL=https://kayad.space
EXTRA_CORS_ORIGINS=https://www.kayad.space
WEBHOIST_EMAIL=owner@kayad.space
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@kayad.space
SENDGRID_API_KEY=

# ── SMS / WHATSAPP ───────────────────────────────────────────[OPTIONAL]
SMS_PROVIDER=mock
AT_API_KEY=
AT_USERNAME=kayad
AT_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── ESCROW / ALERTS ──────────────────────────────────────────[OPTIONAL]
ESCROW_ACCOUNT_NUMBER=
ESCROW_BANK_NAME=
ADMIN_EMAIL=
ADMIN_PHONE=

# ── SEED PASSWORDS ───────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@kayad.space"
SEED_ADMIN_PASSWORD="change-me-admin-strong-password"
SEED_ADMIN_NAME="Platform Admin"
SEED_INSPECTOR_PW="change-me-inspector-strong-password"
SEED_ADMIN_PW="change-me-admin-pw"
SEED_HR_PW="change-me-hr-pw"
SEED_ACCOUNTS_PW="change-me-accounts-pw"
SEED_ESCROW_PW="change-me-escrow-pw"
SEED_MARKET_PW="change-me-market-pw"
SEED_ADS_PW="change-me-ads-pw"
SEED_SUPPORT_PW="change-me-support-pw"
SEED_MOD_PW="change-me-mod-pw"
SEED_DEALER_PW="change-me-dealer-pw"
SEED_SELLER_PW="change-me-seller-pw"
SEED_BUYER_PW="change-me-buyer-pw"
SEED_ELITE_PW="change-me-elite-pw"
SEED_PENDING_PW="change-me-pending-pw"

# ── BACKGROUND JOBS ──────────────────────────────────────────[OPTIONAL]
ESCROW_AUTO_RELEASE_DAYS=7
ESCROW_CRON_ENABLED=true
AUCTION_REMINDER_ENABLED=true

# ── MONITORING ───────────────────────────────────────────────[OPTIONAL]
SENTRY_DSN=
SENTRY_TRACE_RATE=0.1
