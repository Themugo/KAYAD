# ── FRONTEND (Vite) — Required for dev ────────────────────────────────
# Obtain these from your Supabase project dashboard: Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ── FRONTEND — Feature flags ──────────────────────────────────────────
VITE_ENABLE_CHAT=true
VITE_ENABLE_ESCROW=true
VITE_ENABLE_AUCTIONS=true
VITE_ENABLE_COMPARE=true
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_DEMO=false
VITE_APP_NAME=Kayad Dev
VITE_DOMAIN=localhost:3000

# ── SECURITY ────────────────────────────────────────────────────────────
# Session timeout in milliseconds (default: 30 minutes)
VITE_SESSION_TIMEOUT=1800000

# Enable security features
VITE_SECURITY_LOGGING=true
VITE_ENABLE_CSRF_PROTECTION=true

# Content Security Policy (optional overrides)
# VITE_CSP_REPORT_URI=https://your-csp-reporter.example.com/csp-report
