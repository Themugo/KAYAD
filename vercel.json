{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/((?!assets/|favicon\\.svg$|manifest\\.webmanifest$|registerSW\\.js$|sw\\.js$|workbox-|stats\\.html$).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://kayad-backend.onrender.com; frame-ancestors 'none'"
        }
      ]
    }
  ],
  "env": {
    "VITE_API_URL": "https://kayad-backend.onrender.com",
    "VITE_SOCKET_URL": "wss://kayad-backend.onrender.com",
    "VITE_SUPABASE_URL": "https://leximzdduxbcgwaxyhva.supabase.co",
    "VITE_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxleGltemRkdXhiY2d3YXh5aHZhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODM2MTM0MzIsImV4cCI6MjA5OTE4OTQzMn0.bQxDKi6H0ooTwgKthszveX2OMjF7JQk3jFwZkCSSnY4"
  }
}
