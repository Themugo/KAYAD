{
  "name": "kayad-frontend",
  "version": "2.0.0",
  "description": "Kayad — Kenya's Premium Car Marketplace — Live Bidding, Escrow, M-Pesa",
  "type": "module",
  "engines": {
    "node": "20.x || 24.x || 26.x"
  },
  "scripts": {
    "dev": "vite --port 3000",
    "dev:staging": "vite --port 3000 --mode staging",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config e2e/playwright.config.js",
    "audit": "npm audit --omit=dev",
    "audit:fix": "npm audit fix --omit=dev"
  },
  "dependencies": {
    "@sentry/react": "^10.56.0",
    "@testing-library/dom": "^10.4.1",
    "axios": "^1.6.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.460.0",
    "posthog-js": "^1.382.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.30.4",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "ws": "^8.20.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
