{
  "name": "kayad-frontend",
  "version": "2.0.0",
  "description": "Kayad — Kenya's Premium Car Marketplace — Live Bidding, Escrow, M-Pesa",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:staging": "vite --port 3000 --mode staging",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config e2e/playwright.config.js"
  },
  "dependencies": {
    "@sentry/react": "^8.0.0",
    "axios": "^1.6.0",
    "lucide-react": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^25.0.0",
    "playwright": "^1.60.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "ws": "^8.20.1"
  }
}
