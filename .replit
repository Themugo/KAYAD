modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["npm", "install"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "nodejs-24"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
