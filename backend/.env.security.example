# =============================================================================
# KAYAD SECURITY CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env files with real secrets to version control

# =============================================================================
# AUTHENTICATION & SESSIONS
# =============================================================================

# JWT Secret - CRITICAL: Use a strong random string (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# Session secret for cookie encryption
SESSION_SECRET=your-session-secret-minimum-32-chars

# Token version for JWT (increment to invalidate all existing tokens)
JWT_VERSION=1

# Session timeout in minutes (default: 30)
SESSION_TIMEOUT_MINUTES=30

# Maximum concurrent sessions per user (default: 5)
MAX_SESSIONS_PER_USER=5

# =============================================================================
# RATE LIMITING
# =============================================================================

# Global rate limit - requests per window
RATE_LIMIT_MAX=500

# Auth rate limit - login attempts per window
AUTH_RATE_LIMIT_MAX=20

# Admin rate limit - requests per window
ADMIN_RATE_LIMIT_MAX=200

# =============================================================================
# PASSWORD SECURITY
# =============================================================================

# Minimum password length (default: 8)
PASSWORD_MIN_LENGTH=8

# Require password complexity (default: true)
PASSWORD_REQUIRE_COMPLEXITY=true

# Password history count (prevent password reuse)
PASSWORD_HISTORY_COUNT=5

# =============================================================================
# API SECURITY
# =============================================================================

# API Key for admin operations
ADMIN_API_KEY=your-admin-api-key

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://kayad-motors.vercel.app,https://www.yourdomain.com

# Extra CORS origins
EXTRA_CORS_ORIGINS=

# Frontend URL for security headers
FRONTEND_URL=https://kayad-motors.vercel.app

# Custom domain (if using)
CUSTOM_DOMAIN=

# =============================================================================
# REQUEST LIMITS
# =============================================================================

# Maximum request body size in bytes (default: 2MB)
MAX_REQUEST_SIZE=2097152

# Maximum query limit (default: 100)
MAX_QUERY_LIMIT=100

# Default query limit (default: 20)
DEFAULT_QUERY_LIMIT=20

# =============================================================================
# FILE UPLOAD SECURITY
# =============================================================================

# Maximum file upload size in bytes (default: 5MB)
MAX_UPLOAD_SIZE=5242880

# Maximum number of files per upload
MAX_UPLOAD_COUNT=10

# =============================================================================
# PAYMENT & FINANCIAL SECURITY
# =============================================================================

# M-Pesa Security Configuration
MPESA_SHORTCODE=your-mpesa-shortcode
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback

# Allowed M-Pesa callback IPs
MPESA_ALLOWED_IPS=your-mpesa-ip-1,your-mpesa-ip-2

# Payment webhook secret
PAYMENT_WEBHOOK_SECRET=your-payment-webhook-secret

# =============================================================================
# DATABASE SECURITY
# =============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# MONITORING & AUDIT
# =============================================================================

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# Enable security audit logging
ENABLE_AUDIT_LOGGING=true

# Audit log retention in days
AUDIT_LOG_RETENTION_DAYS=90

# =============================================================================
# SECURITY FEATURES
# =============================================================================

# Require email verification (default: true)
REQUIRE_EMAIL_VERIFICATION=true

# Enable IP allowlisting for admin (default: false)
ADMIN_IP_ALLOWLIST_ENABLED=false
ADMIN_ALLOWED_IPS=

# Enable concurrent session enforcement (default: true)
ENFORCE_CONCURRENT_SESSIONS=true

# Enable suspicious activity detection (default: true)
SUSPICIOUS_ACTIVITY_DETECTION=true

# =============================================================================
# SSL & ENCRYPTION
# =============================================================================

# Force HTTPS (default: true in production)
FORCE_HTTPS=true

# HSTS max-age in seconds (default: 31536000 = 1 year)
HSTS_MAX_AGE=31536000

# =============================================================================
# OAUTH PROVIDERS (if using)
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# =============================================================================
# CLOUDINARY (for image uploads)
# =============================================================================

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# =============================================================================
# EMAIL PROVIDER (for transactional emails)
# =============================================================================

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-email@domain.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@your-domain.com

# =============================================================================
# REDIS (for caching & queues)
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================================================
# ENVIRONMENT
# =============================================================================

NODE_ENV=development
