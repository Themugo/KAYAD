{
  "name": "kayad-backend",
  "version": "2.0.0",
  "description": "Kayad API — Live Auctions, M-Pesa, Escrow",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": "20.x || 24.x || 26.x"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node seed.js",
    "dev:node20": "node node_modules/nodemon/bin/nodemon.js server.js",
    "start:node20": "node server.js",
    "seed:node20": "node seed.js",
    "test:node20": "node node_modules/jest/bin/jest.js --forceExit",
    "seed-depts": "node scripts/seed-departments.js",
    "format": "prettier --write \"**/*.{js,json,css}\"",
    "format:check": "prettier --check \"**/*.{js,json,css}\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --coverage",
    "backup": "node scripts/backup.js",
    "backup:status": "node scripts/backup.js status",
    "release": "semantic-release"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@sendgrid/mail": "^8.1.4",
    "@sentry/node": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.1.6",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "isomorphic-dompurify": "^2.14.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.0",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-rotate": "^0.3.0",
    "posthog-node": "^4.0.0",
    "prom-client": "^15.1.3",
    "redis": "^6.0.0",
    "set-blocking": "^2.0.0",
    "sharp": "^0.35.1",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^10.0.4",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^11.0.4",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.5",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "ws": "^8.20.1"
  }
}
