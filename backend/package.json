{
  "name": "kayad-backend",
  "version": "2.0.0",
  "description": "Kayad API — Live Auctions, M-Pesa, Escrow",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node seed.js",
    "setup:supabase": "node ../scripts/setup-supabase.js",
    "setup:verify": "node ../scripts/setup-supabase.js --verify",
    "setup:storage": "node ../scripts/setup-supabase.js --storage",
    "dev:node20": "node node_modules/nodemon/bin/nodemon.js server.js",
    "start:node20": "node server.js",
    "seed:node20": "node seed.js",
    "test:node20": "node node_modules/jest/bin/jest.js --forceExit",
    "seed-depts": "node scripts/seed-departments.js",
    "format": "prettier --write \"**/*.{js,json,css}\"",
    "format:check": "prettier --check \"**/*.{js,json,css}\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --passWithNoTests",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --passWithNoTests --coverage",
    "backup": "node scripts/backup.js",
    "backup:status": "node scripts/backup.js status",
    "release": "semantic-release",
    "monitor": "node scripts/deploymentMonitor.js monitor",
    "health-check": "node scripts/deploymentMonitor.js check",
    "notify-deployment": "node scripts/deploymentMonitor.js notify"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.65.0",
    "@sentry/profiling-node": "^10.65.0",
    "@supabase/supabase-js": "^2.110.2",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "isomorphic-dompurify": "^2.36.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "posthog-node": "^4.18.0",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "stripe": "^22.3.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^10.0.4",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^11.0.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.6",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "ws": "^8.20.1",
    "minimist": "^1.2.8"
  }
}
