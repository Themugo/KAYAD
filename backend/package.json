{
  "name": "kayad-backend",
  "version": "2.0.0",
  "description": "Kayad API — Live Auctions, M-Pesa, Escrow",
  "main": "server.ts",
  "type": "module",
  "engines": {
    "node": "20.x || 24.x || 26.x"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node server.ts",
    "dev:js": "nodemon server.js",
    "start": "node server.js",
    "start:js": "node server.js",
    "seed": "ts-node seed.ts",
    "seed:js": "node seed.js",
    "dev:node20": "node node_modules/nodemon/bin/nodemon.js server.js",
    "start:node20": "node server.js",
    "seed:node20": "node seed.js",
    "test:node20": "node node_modules/jest/bin/jest.js --forceExit",
    "seed-depts": "ts-node scripts/seed-departments.ts",
    "format": "prettier --write \"**/*.{js,json,css,ts}\"",
    "format:check": "prettier --check \"**/*.{js,json,css,ts}\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --coverage",
    "type-check": "tsc --noEmit",
    "backup": "ts-node scripts/backup.ts",
    "backup:status": "ts-node scripts/backup.ts status"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "@sentry/node": "^10.57.0",
    "@sentry/profiling-node": "^10.57.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-rotate": "^0.3.0",
    "posthog-node": "^4.0.0",
    "redis": "^6.0.0",
    "sharp": "^0.35.1",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.4.5",
    "zod": "^3.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "ws": "^8.20.1"
  }
}
