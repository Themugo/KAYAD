{
  "name": "kayad-backend",
  "version": "2.0.0",
  "description": "Kayad API — Live Auctions, M-Pesa, Escrow",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node seed.js",
    "seed-depts": "node scripts/seed-departments.js",
    "format": "prettier --write \"**/*.{js,json,css}\"",
    "format:check": "prettier --check \"**/*.{js,json,css}\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit --coverage",
    "backup": "bash scripts/backup.sh"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.4",
    "@sentry/node": "^8.0.0",
    "@sentry/profiling-node": "^8.0.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "ws": "^8.20.1"
  }
}
