# =============================
# 🌍 APP
# =============================
NODE_ENV=production
PORT=5000

# =============================
# 🗄 DATABASE — MongoDB Atlas
# =============================
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/gari-motors

# =============================
# 🔐 AUTH
# =============================
JWT_SECRET=<generate with: openssl rand -hex 32>
REFRESH_TOKEN_SECRET=<generate different one>
JWT_EXPIRE=7d

# =============================
# 🌐 CORS — Frontend URL (Vercel)
# =============================
FRONTEND_URL=https://garimotors.co.ke

# =============================
# 💳 MPESA (Daraja API)
# =============================
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_SECRET=your_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://gari-backend.onrender.com/api/payments/callback

# =============================
# ☁️ CLOUDINARY (Car images)
# =============================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =============================
# 📧 EMAIL (optional)
# =============================
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=re_api_key
EMAIL_FROM=noreply@garimotors.co.ke

# =============================
# 📱 SMS (optional)
# =============================
SMS_PROVIDER=mock

# =============================
# 🍃 SENTRY (optional)
# =============================
SENTRY_DSN=https://xxx@sentry.io/xxx
