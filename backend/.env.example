# ═══════════════════════════════════════════════════════════════════════════
# KAYAD BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# ─── SERVER CONFIGURATION ────────────────────────────────────────────────
NODE_ENV=your_value_here
PORT=your_value_here

# ─── SUPABASE (PostgreSQL, Storage, Auth) ───────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=your_value_here
SUPABASE_SERVICE_KEY=your_value_here
SUPABASE_BUCKET=your_value_here

# ─── AUTHENTICATION TOKENS ───────────────────────────────────────────────
# Generate strong random strings (32+ characters each)
JWT_SECRET=your_value_here
REFRESH_TOKEN_SECRET=your_value_here
SESSION_SECRET=your_value_here

# Token expiry settings
ACCESS_TOKEN_EXPIRE=your_value_here
REFRESH_TOKEN_EXPIRE=your_value_here
ACCESS_COOKIE_MS=your_value_here

# ─── CORS CONFIGURATION ─────────────────────────────────────────────────
# URLs that can access the API (comma-separated for multiple)
FRONTEND_URL=your_value_here
BACKEND_URL=your_value_here

# ─── MPESA (Kenyan Mobile Payments) ──────────────────────────────────────
# Get from: https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_value_here
MPESA_CONSUMER_SECRET=your_value_here
MPESA_SHORTCODE=your_value_here
MPESA_PASSKEY=your_value_here
MPESA_CALLBACK_URL=your_value_here
MPESA_ENV=your_value_here
MPESA_SKIP_IP_CHECK=your_value_here
MPESA_EXTRA_IPS=your_value_here

# ─── AFRICA'S TALKING (SMS/OTP) ──────────────────────────────────────────
# Get from: https://africastalking.com/
AT_API_KEY=your_value_here
AT_USERNAME=your_value_here
AT_SENDER_ID=your_value_here
SMS_PROVIDER=your_value_here

# ─── EMAIL (SendGrid) ────────────────────────────────────────────────────
# Get from: https://signup.sendgrid.com/
SENDGRID_API_KEY=your_value_here
EMAIL_FROM=your_value_here

# ─── TWILIO (WhatsApp) ───────────────────────────────────────────────────
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_value_here
TWILIO_AUTH_TOKEN=your_value_here
TWILIO_WHATSAPP_NUMBER=your_value_here

# ─── CLOUDINARY (Image Storage) ──────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_value_here
CLOUDINARY_API_KEY=your_value_here
CLOUDINARY_API_SECRET=your_value_here

# ─── REDIS (Caching) ─────────────────────────────────────────────────────
# Leave empty for in-memory caching (development)
REDIS_URL=your_value_here
REDIS_HOST=your_value_here
REDIS_PORT=your_value_here
REDIS_PASSWORD=your_value_here

# ─── POSTHOG ANALYTICS ────────────────────────────────────────────────────
# Get from: https://posthog.com → Project Settings
POSTHOG_API_KEY=your_value_here
POSTHOG_HOST=your_value_here

# ─── SENTRY ERROR TRACKING ────────────────────────────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=your_value_here

# ─── ESCROW CONFIGURATION ────────────────────────────────────────────────
ESCROW_ACCOUNT_NUMBER=your_value_here
ESCROW_BANK_NAME=your_value_here
ESCROW_AUTO_RELEASE_DAYS=your_value_here
ESCROW_CRON_ENABLED=your_value_here
KAYAD_MASTER_PAYBILL=your_value_here

# ─── AUCTION SETTINGS ───────────────────────────────────────────────────
AUCTION_SNIPE_WINDOW_SECONDS=your_value_here
AUCTION_SNIPE_EXTENSION_SECONDS=your_value_here
AUCTION_MAX_EXTENSIONS=your_value_here
AUCTION_MAX_TOTAL_EXTENSION_SECONDS=your_value_here
AUCTION_REMINDER_ENABLED=your_value_here

# ─── REFERRAL SYSTEM ─────────────────────────────────────────────────────
REFERRAL_BONUS_KES=your_value_here

# ─── PLATFORM FEES (seeded to database) ─────────────────────────────────
LISTING_FEE_KES=your_value_here
AUCTION_REG_FEE_KES=your_value_here
GHOST_CHECK_FEE_KES=your_value_here
PLATFORM_COMMISSION_PERCENT=your_value_here

# ─── RATE LIMITING ───────────────────────────────────────────────────────
RATE_LIMIT_MAX=your_value_here
AUTH_RATE_LIMIT_MAX=your_value_here

# ─── SECURITY ────────────────────────────────────────────────────────────
MAX_QUERY_LIMIT=your_value_here
DEFAULT_QUERY_LIMIT=your_value_here
MAX_BODY_BYTES=your_value_here
SECURITY_ALERT_EMAIL=your_value_here

# ─── SEED ACCOUNTS ───────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=your_value_here
SEED_ADMIN_PASSWORD=your_value_here
SEED_ADMIN_NAME=your_value_here

# Platform owner (bypasses all checks - set your email)
WEBHOIST_EMAIL=your_value_here

# Seed account passwords (for testing)
SEED_ADMIN_PW=your_value_here
SEED_HR_PW=your_value_here
SEED_ACCOUNTS_PW=your_value_here
SEED_ESCROW_PW=your_value_here
SEED_MARKET_PW=your_value_here
SEED_ADS_PW=your_value_here
SEED_SUPPORT_PW=your_value_here
SEED_MOD_PW=your_value_here
SEED_DEALER_PW=your_value_here
SEED_SELLER_PW=your_value_here
SEED_BUYER_PW=your_value_here
SEED_ELITE_PW=your_value_here
SEED_PENDING_PW=your_value_here
SEED_WEBHOST_PW=your_value_here

# ─── APP INFO ────────────────────────────────────────────────────────────
APP_VERSION=your_value_here
APP_NAME=your_value_here
