# =====================================================================
#  KAYAD BACKEND — Production Environment Variables
#  Copy to backend/.env and fill in real values
# =====================================================================

# ─── SERVER & DATABASE ───────────────────────────────────────────────
NODE_ENV=production
PORT=5000
MONGO_URI="mongodb+srv://user:password@cluster.mongodb.net/kayad?retryWrites=true&w=majority"
MONGO_POOL_SIZE=10
TEST_MONGO_URI="mongodb://127.0.0.1:27017/kayad-test"
JWT_SECRET="<generate-32-char-random-string>"
REFRESH_TOKEN_SECRET="<generate-different-32-char-string>"
SESSION_SECRET="<generate-another-32-char-string>"
ACCESS_TOKEN_EXPIRE=1h        # access token lifetime (default 1h)
REFRESH_TOKEN_EXPIRE=7d       # refresh token lifetime (default 7d)
ACCESS_COOKIE_MS=3600000     # access token cookie maxAge in ms (default 1h = 3600000)

# ─── MONGODB REPLICA SET (Scalability) ───────────────────────────────
MONGO_REPLICA_SET_NAME=kayadReplicaSet
MONGO_READ_PREFERENCE=secondaryPreferred
MONGO_WRITE_CONCERN_W=majority
MONGO_WRITE_CONCERN_J=true
MONGO_WRITE_TIMEOUT=5000
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_MAX_IDLE_TIME=30000
MONGO_WAIT_QUEUE_TIMEOUT=5000
MONGO_SOCKET_TIMEOUT=45000
MONGO_SERVER_SELECTION_TIMEOUT=5000
MONGO_HEARTBEAT_FREQUENCY=10000

# ─── MONGODB REPLICA SET HOSTS (for replica set setup) ────────────────
MONGO_REPLICA_SET_HOSTS=localhost:27017,localhost:27018,localhost:27019

# ─── CORS — Frontend URL (Vercel) ───────────────────────────────────
FRONTEND_URL=https://kayad.space
BACKEND_URL=https://api.kayad.space

# ─── MPESA DARJA API (Official Safaricom) ───────────────────────────
MPESA_CONSUMER_KEY="<get-from-mpesa-developer-portal>"
MPESA_CONSUMER_SECRET="<get-from-mpesa-developer-portal>"
MPESA_SHORTCODE="your_paybill_or_till"
MPESA_PASSKEY="your_lipa_na_mpesa_passkey"
MPESA_CALLBACK_URL="https://api.kayad.space/api/payments/callback"
MPESA_ENV=sandbox          # sandbox | production
MPESA_SKIP_IP_CHECK=false  # set true for local dev only
MPESA_EXTRA_IPS=""          # comma-separated custom IPs for callback whitelist

# ─── SMS & OTP (Africa's Talking - Standard for Kenya) ─────────────
AT_API_KEY="your_africas_talking_api_key"
AT_USERNAME="<your_africas_talking_username>"
AT_SENDER_ID="<your_sender_id>"
SMS_PROVIDER=mock          # mock | africastalking | twilio

# ─── EMAIL (SendGrid / Nodemailer) ──────────────────────────────────
SENDGRID_API_KEY="your_sendgrid_key"
EMAIL_FROM="notifications@kayad.space"

# ─── WHATSAPP API (Meta/Twilio) ────────────────────────────────────
TWILIO_ACCOUNT_SID="your_sid"
TWILIO_AUTH_TOKEN="your_token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+254..."

# ─── CLOUDINARY (For Car Images & Ghost-Check Videos) ──────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── SUPABASE (Storage & Auth) ─────────────────────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="your_supabase_service_role_key"
SUPABASE_BUCKET="kayad-images"  # Storage bucket name (create in Supabase dashboard)
# Note: When SUPABASE_URL is configured, images will use Supabase Storage
# Falls back to Cloudinary if Supabase is not configured

# ─── AUCTION SNIPE GUARD ─────────────────────────────────────────────
AUCTION_SNIPE_WINDOW_SECONDS=120       # extend when < 120s remain
AUCTION_SNIPE_EXTENSION_SECONDS=120    # extend by 120s
AUCTION_MAX_EXTENSIONS=5               # max snipe extensions per auction
AUCTION_MAX_TOTAL_EXTENSION_SECONDS=600# total extension cap (10 min)
AUCTION_REMINDER_ENABLED=true          # cron: send bid reminders

# ─── ESCROW SETTINGS ────────────────────────────────────────────────
ESCROW_ACCOUNT_NUMBER=""         # platform escrow bank account number
ESCROW_BANK_NAME="Equity Bank Kenya"
ESCROW_AUTO_RELEASE_DAYS=7       # days after delivery before auto-release
ESCROW_CRON_ENABLED=true         # escrow auto-release cron

# ─── REFERRAL SYSTEM ──────────────────────────────────────────────
REFERRAL_BONUS_KES=500  # credit awarded to referrer per signup

# ─── SENTRY (Error Tracking) ────────────────────────────────────────
SENTRY_DSN=""                       # https://xxx@sentry.io/xxx (empty = disabled)
VITE_SENTRY_DSN=""                  # Frontend Sentry DSN (same as above for Vite)

# ─── POSTHOG (Error Tracking & Analytics) ──────────────────────────
POSTHOG_API_KEY=""                  # your PostHog API key (empty = disabled)
POSTHOG_HOST="https://us.i.posthog.com"  # PostHog host

# ─── REDIS (Caching / Rate Limiting) ───────────────────────────────
REDIS_URL=""                       # redis://... (empty = in-memory fallback)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=""                  # Redis password if required

# ─── REDIS CLUSTER (Advanced Caching) ───────────────────────────────
REDIS_HOST_1=redis-1
REDIS_PORT_1=6379
REDIS_HOST_2=redis-2
REDIS_PORT_2=6379
REDIS_HOST_3=redis-3
REDIS_PORT_3=6379

# ─── SMTP (Alternative Email) ──────────────────────────────────────
EMAIL_HOST="smtp.gmail.com"         # smtp host (empty = disabled)
EMAIL_PORT=587
EMAIL_USER="your@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="your@gmail.com"
REQUIRE_EMAIL_VERIFICATION=true

# ─── SECURITY ALERTS ────────────────────────────────────────────────
SECURITY_ALERT_EMAIL="admin@kayad.space"   # receives critical security alerts (comma-separated)
SECURITY_SLACK_WEBHOOK=""                  # Slack webhook for security alerts (empty = disabled)
SIEM_ENABLED=false                         # structured log forwarding for SIEM collection

# ─── ADMIN ALERTS ───────────────────────────────────────────────────
ADMIN_EMAIL="admin@kayad.space"    # receives system alerts
ADMIN_PHONE="+2547..."             # receives SMS alerts

# ─── ESCROW VAULT ──────────────────────────────────────────────────
KAYAD_MASTER_PAYBILL="<your_mpesa_paybill>"      # M-Pesa paybill for bid security

# ─── RATE LIMITING ─────────────────────────────────────────────────
RATE_LIMIT_MAX=500                 # global requests per window
AUTH_RATE_LIMIT_MAX=20             # auth endpoints per window

# ─── SECURITY ──────────────────────────────────────────────────────
MAX_QUERY_LIMIT=100                # max ?limit value
DEFAULT_QUERY_LIMIT=20             # default ?limit value
MAX_BODY_BYTES=2097152             # 2MB

# ─── METADATA ──────────────────────────────────────────────────────
APP_VERSION=2.0.0
APP_NAME=Kayad
EXTRA_CORS_ORIGINS=""              # comma-separated additional origins

# ─── GLOBAL SYSTEM FEES (seeded into DB at init) ────────────────────
LISTING_FEE_KES=1000
AUCTION_REG_FEE_KES=2000
GHOST_CHECK_FEE_KES=2500
PLATFORM_COMMISSION_PERCENT=2

# ─── SEED SCRIPT ─────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@kayad.space"
SEED_ADMIN_PASSWORD="<set-a-strong-password>"
SEED_ADMIN_NAME="Platform Admin"

# ─── PLATFORM OWNERS (webhoist) ──────────────────────────────────────
# Comma-separated list of owner emails. Each becomes an immutable superadmin
# that bypasses all checks and cannot be edited/deleted by other admins.
# The FIRST is the primary owner (cannot be suspended at all).
WEBHOIST_EMAIL="owner@example.com"

# ─── SEED ACCOUNT PASSWORDS (set unique strong passwords in production) ─
# These default passwords are KNOWN and must be overridden in production:
SEED_ADMIN_PW="<override-in-production>"
SEED_HR_PW="<override-in-production>"
SEED_ACCOUNTS_PW="<override-in-production>"
SEED_ESCROW_PW="<override-in-production>"
SEED_MARKET_PW="<override-in-production>"
SEED_ADS_PW="<override-in-production>"
SEED_SUPPORT_PW="<override-in-production>"
SEED_MOD_PW="<override-in-production>"
SEED_DEALER_PW="<override-in-production>"
SEED_SELLER_PW="<override-in-production>"
SEED_BUYER_PW="<override-in-production>"
SEED_ELITE_PW="<override-in-production>"
SEED_PENDING_PW="<override-in-production>"
SEED_WEBHOST_PW="<set-a-strong-password>"
