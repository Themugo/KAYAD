# =====================================================================
#  GARI MOTORS BACKEND — Complete Environment Variables
#  Copy to .env — every variable documented
#  Integrations marked [OPTIONAL] activate only when set
# =====================================================================

# ── SERVER ────────────────────────────────────────────────────────────
NODE_ENV=production                         # development | production
PORT=5000
APP_NAME=Gari Motors
APP_VERSION=2.0.0

# ── MONGODB ───────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/gari-motors?retryWrites=true&w=majority
MONGO_POOL_SIZE=10                          # DB connection pool size

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=minimum-32-random-chars-here-change-this
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=different-32-random-chars-here

# ── FRONTEND ──────────────────────────────────────────────────────────
FRONTEND_URL=https://garimotors.co.ke
EXTRA_CORS_ORIGINS=                        # comma-separated extra origins

# ── M-PESA (SAFARICOM DARAJA) ─────────────────────────────────────────
MPESA_ENV=production                       # production | sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_business_shortcode
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_CALLBACK_URL=https://garimotors.co.ke/api/payments/callback
MPESA_SKIP_IP_CHECK=false                  # true only for local dev
MPESA_EXTRA_IPS=                           # extra allowed IPs (comma-sep)

# ── CLOUDINARY ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── EMAIL (SMTP) ─────────────────────────────────────────────[OPTIONAL]
# Leave blank to disable. Works with Gmail, Mailgun, SendGrid, Resend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@garimotors.co.ke
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@garimotors.co.ke
# For Resend (recommended): EMAIL_HOST=smtp.resend.com EMAIL_PORT=465

# ── SENTRY ERROR TRACKING ────────────────────────────────[OPTIONAL]
# 1. Sign up at sentry.io (free)
# 2. Create a Node.js project
# 3. Copy the DSN here — monitoring activates automatically
SENTRY_DSN=
SENTRY_TRACE_RATE=0.1                      # 0.0–1.0 (10% of requests)
SENTRY_FORCE=false                         # true to enable in development

# ── REDIS CACHE ───────────────────────────────────────────[OPTIONAL]
# Falls back to in-memory if not set. Redis dramatically improves perf.
# Free Redis: Upstash (upstash.com) — copy the redis:// URL here
REDIS_URL=
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://:password@your-upstash-endpoint:6379

# ── PLATFORM FEES ─────────────────────────────────────────────────────
LISTING_FEE_KES=500                        # Per-listing fee (dealers)
FEATURED_FEE_KES=2000                      # Weekly featured listing
AUCTION_FEE_KES=1000                       # Per-auction fee
ESCROW_PLATFORM_FEE_PERCENT=1.5            # % on escrow release
BID_COMMITMENT_PERCENT=5                   # % of bid as M-Pesa deposit

# ── ESCROW CRON ───────────────────────────────────────────────────────
ESCROW_AUTO_RELEASE_DAYS=7                 # Days before auto-release
ESCROW_CRON_ENABLED=true                   # false to disable cron

# ── RATE LIMITING ─────────────────────────────────────────────────────
RATE_LIMIT_MAX=500                         # Requests per 15min (global)
AUTH_RATE_LIMIT_MAX=20                     # Requests per 15min (auth)
MAX_QUERY_LIMIT=100                        # Max ?limit= value
DEFAULT_QUERY_LIMIT=20                     # Default ?limit= value
MAX_BODY_BYTES=2097152                     # Max request body (2MB)

# ── BACKUP ────────────────────────────────────────────────[OPTIONAL]
BACKUP_DIR=/var/backups/gari-motors
BACKUP_KEEP_DAYS=7
# AWS_S3_BUCKET=gari-motors-backups        # Upload to S3
# GCS_BUCKET=gari-motors-backups           # Upload to GCS

# ── SMS (AFRICA'S TALKING) ────────────────────────────────[OPTIONAL]
# AT_API_KEY=your_africas_talking_api_key
# AT_USERNAME=your_username
# AT_SENDER_ID=GariMotors
