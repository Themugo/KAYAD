# ═══════════════════════════════════════════════════════════════════════════
# KAYAD BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# ─── MOCK MODE (for development/testing) ────────────────────────────────
# Set to true to use mock services instead of real APIs
MOCK_MODE=true

# ─── SERVER CONFIGURATION ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── SUPABASE (PostgreSQL, Storage, Auth) ───────────────────────────────
# Get these from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://jypkhvknfgoqrhwzbdwi.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp5cGtodmtuZmdvcXJod3piZHdpIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MzI3ODQwMSwiZXhwIjoyMDk4ODU0NDAxfQ.hZMdBaH6b_12KSMjhX8Ib2dPH8T_Jb0utSCYfL9iDik
SUPABASE_BUCKET=vehicle-images

# ─── AUTHENTICATION TOKENS ───────────────────────────────────────────────
# Generate strong random strings (32+ characters each)
JWT_SECRET=change-this-to-a-strong-random-32-char-string
REFRESH_TOKEN_SECRET=change-this-to-another-strong-32-char-string
SESSION_SECRET=change-this-to-a-third-32-char-string

# Token expiry settings
ACCESS_TOKEN_EXPIRE=1h
REFRESH_TOKEN_EXPIRE=7d
ACCESS_COOKIE_MS=3600000

# ─── CORS CONFIGURATION ─────────────────────────────────────────────────
# URLs that can access the API (comma-separated for multiple)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ─── MPESA (Kenyan Mobile Payments) ──────────────────────────────────────
# Get from: https://developer.safaricom.co.ke/
# Disabled for mock mode - enable for production
# MPESA_CONSUMER_KEY=DrakdzC1QnxFQsYZXpBqvSJsJcby02coT03TWCNYVlLOHxGD
