# ─── AFRICA'S TALKING (SMS/OTP) ──────────────────────────────────────────
# Get from: https://africastalking.com/
AT_API_KEY=atsk_28abec084343187cf6eefabb359823dab8deb1e98afacbf169971db93b858f9952ac6c67
AT_USERNAME=sandbox
AT_SENDER_ID=KAYAD
SMS_PROVIDER=mock

# ─── EMAIL (SendGrid) ────────────────────────────────────────────────────
# Get from: https://signup.sendgrid.com/
# For production, enable these:
# SENDGRID_API_KEY=SG.your_api_key
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.your_api_key
# EMAIL_FROM=noreply@kayad.space
# EMAIL_ENABLED=true

# ─── TWILIO (WhatsApp) ───────────────────────────────────────────────────
# Get from: https://console.twilio.com/
# Disabled for mock mode - enable for production
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_ENABLED=false

# ─── CLOUDINARY (Image Storage) ──────────────────────────────────────────
# Get from: https://cloudinary.com/console
# Disabled for mock mode - enable for production
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
IMAGE_PROVIDER=supabase

# ─── REDIS (Caching) ─────────────────────────────────────────────────────
# Leave empty for in-memory caching (development)
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── POSTHOG ANALYTICS ────────────────────────────────────────────────────
# Get from: https://posthog.com → Project Settings
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─── SENTRY ERROR TRACKING ────────────────────────────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=

# ─── ESCROW CONFIGURATION ────────────────────────────────────────────────
ESCROW_ACCOUNT_NUMBER=
ESCROW_BANK_NAME=Equity Bank Kenya
ESCROW_AUTO_RELEASE_DAYS=7
ESCROW_CRON_ENABLED=true
KAYAD_MASTER_PAYBILL=

# ─── AUCTION SETTINGS ───────────────────────────────────────────────────
AUCTION_SNIPE_WINDOW_SECONDS=120
AUCTION_SNIPE_EXTENSION_SECONDS=120
AUCTION_MAX_EXTENSIONS=5
AUCTION_MAX_TOTAL_EXTENSION_SECONDS=600
AUCTION_REMINDER_ENABLED=true

# ─── REFERRAL SYSTEM ─────────────────────────────────────────────────────
REFERRAL_BONUS_KES=500

# ─── PLATFORM FEES (seeded to database) ─────────────────────────────────
LISTING_FEE_KES=0
AUCTION_REG_FEE_KES=0
GHOST_CHECK_FEE_KES=0
PLATFORM_COMMISSION_PERCENT=2

# ─── RATE LIMITING ───────────────────────────────────────────────────────
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20

# ─── SECURITY ────────────────────────────────────────────────────────────
MAX_QUERY_LIMIT=100
DEFAULT_QUERY_LIMIT=20
MAX_BODY_BYTES=2097152
SECURITY_ALERT_EMAIL=admin@kayad.space

# ─── SEED ACCOUNTS ───────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@kayad.space
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Platform Admin

# Platform owner (bypasses all checks - set your email)
WEBHOIST_EMAIL=owner@example.com

# Seed account passwords (for testing)
