# =====================================================================
#  KAYAD SCALABILITY DEPLOYMENT - Environment Configuration Template
#  Copy this file to backend/.env and fill in your actual values
#  DO NOT commit backend/.env to version control
# =====================================================================

# ─── SERVER & DATABASE ───────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# MongoDB Connection String (Update with your actual MongoDB connection)
# For local development with single instance:
# MONGO_URI=mongodb://localhost:27017/kayad
# For replica set deployment:
MONGO_URI=mongodb://admin:YOUR_MONGODB_PASSWORD@mongodb-primary:27017,mongodb-secondary1:27017,mongodb-secondary2:27017/kayad?replicaSet=kayadReplicaSet&authSource=admin

# MongoDB Replica Set Configuration
MONGO_REPLICA_SET_NAME=kayadReplicaSet
MONGO_READ_PREFERENCE=secondaryPreferred
MONGO_WRITE_CONCERN_W=majority
MONGO_WRITE_CONCERN_J=true
MONGO_WRITE_TIMEOUT=5000
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10
MONGO_MAX_IDLE_TIME=30000
MONGO_WAIT_QUEUE_TIMEOUT=5000
MONGO_SOCKET_TIMEOUT=45000
MONGO_SERVER_SELECTION_TIMEOUT=5000
MONGO_HEARTBEAT_FREQUENCY=10000

# MongoDB Replica Set Hosts (for setup script)
MONGO_REPLICA_SET_HOSTS=mongodb-primary:27017,mongodb-secondary1:27017,mongodb-secondary2:27017

TEST_MONGO_URI=mongodb://127.0.0.1:27017/kayad-test

# JWT Secrets (Generate strong random strings)
JWT_SECRET=YOUR_SUPER_SECRET_RANDOM_STRING_FOR_JWT_TOKENS
REFRESH_TOKEN_SECRET=YOUR_DIFFERENT_RANDOM_STRING_FOR_REFRESH_TOKENS
ACCESS_TOKEN_EXPIRE=1h
REFRESH_TOKEN_EXPIRE=7d

# ─── CORS — Frontend URL ───────────────────────────────────────────
FRONTEND_URL=https://kayad.space

# ─── MPESA DARJA API (Safaricom) ───────────────────────────────────
MPESA_CONSUMER_KEY=YOUR_MPESA_CONSUMER_KEY
MPESA_CONSUMER_SECRET=YOUR_MPESA_CONSUMER_SECRET
MPESA_SHORTCODE=YOUR_MPESA_SHORTCODE
MPESA_PASSKEY=YOUR_MPESA_PASSKEY
MPESA_CALLBACK_URL=https://api.kayad.space/api/payments/callback
MPESA_ENV=production
MPESA_SKIP_IP_CHECK=false
MPESA_EXTRA_IPS=

# ─── SMS & OTP (Africa's Talking) ───────────────────────────────────
AT_API_KEY=YOUR_AFRICASTALKING_API_KEY
AT_USERNAME=YOUR_AFRICASTALKING_USERNAME
AT_SENDER_ID=YOUR_SENDER_ID
SMS_PROVIDER=africastalking

# ─── EMAIL (SendGrid) ──────────────────────────────────────────────
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
EMAIL_FROM=notifications@kayad.space

# ─── WHATSAPP API (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_NUMBER=whatsapp:+254700000000

# ─── CLOUDINARY (Image Storage) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# ─── AUCTION SETTINGS ───────────────────────────────────────────────
AUCTION_SNIPE_WINDOW_SECONDS=120
AUCTION_SNIPE_EXTENSION_SECONDS=120
AUCTION_MAX_EXTENSIONS=5
AUCTION_MAX_TOTAL_EXTENSION_SECONDS=600
AUCTION_REMINDER_ENABLED=true

# ─── ESCROW SETTINGS ────────────────────────────────────────────────
ESCROW_ACCOUNT_NUMBER=YOUR_ESCROW_ACCOUNT_NUMBER
ESCROW_BANK_NAME=Equity Bank Kenya
ESCROW_AUTO_RELEASE_DAYS=7
ESCROW_CRON_ENABLED=true

# ─── REFERRAL SYSTEM ──────────────────────────────────────────────
REFERRAL_BONUS_KES=500

# ─── POSTHOG (Analytics) ──────────────────────────────────────────
POSTHOG_API_KEY=YOUR_POSTHOG_API_KEY
POSTHOG_HOST=https://us.i.posthog.com

# ─── REDIS (Caching) ───────────────────────────────────────────────
# For Docker Compose deployment:
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# For Redis cluster (advanced):
# REDIS_HOST_1=redis-1
# REDIS_PORT_1=6379
# REDIS_HOST_2=redis-2
# REDIS_PORT_2=6379
# REDIS_HOST_3=redis-3
# REDIS_PORT_3=6379

# ─── SMTP (Email) ─────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your@gmail.com
REQUIRE_EMAIL_VERIFICATION=true

# ─── ADMIN ALERTS ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@kayad.space
ADMIN_PHONE=+254700000000

# ─── ESCROW VAULT ──────────────────────────────────────────────────
KAYAD_MASTER_PAYBILL=YOUR_MPESA_PAYBILL

# ─── RATE LIMITING ─────────────────────────────────────────────────
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=20

# ─── SECURITY ──────────────────────────────────────────────────────
MAX_QUERY_LIMIT=100
DEFAULT_QUERY_LIMIT=20
MAX_BODY_BYTES=2097152

# ─── METADATA ──────────────────────────────────────────────────────
APP_VERSION=2.0.0
APP_NAME=Kayad
EXTRA_CORS_ORIGINS=

# ─── GLOBAL SYSTEM FEES ────────────────────────────────────────────
LISTING_FEE_KES=1000
AUCTION_REG_FEE_KES=2000
GHOST_CHECK_FEE_KES=2500
PLATFORM_COMMISSION_PERCENT=2

# ─── SEED SCRIPT ─────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@kayad.space
SEED_ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD
SEED_ADMIN_NAME=Platform Admin

# ─── PLATFORM OWNERS ────────────────────────────────────────────────
WEBHOIST_EMAIL=owner@kayad.space

# ─── SEED ACCOUNT PASSWORDS ─────────────────────────────────────────
SEED_ADMIN_PW=YOUR_STRONG_PASSWORD
SEED_HR_PW=YOUR_STRONG_PASSWORD
SEED_ACCOUNTS_PW=YOUR_STRONG_PASSWORD
SEED_ESCROW_PW=YOUR_STRONG_PASSWORD
SEED_MARK_PW=YOUR_STRONG_PASSWORD
SEED_ADS_PW=YOUR_STRONG_PASSWORD
SEED_SUPPORT_PW=YOUR_STRONG_PASSWORD
SEED_MOD_PW=YOUR_STRONG_PASSWORD
SEED_DEALER_PW=YOUR_STRONG_PASSWORD
SEED_SELLER_PW=YOUR_STRONG_PASSWORD
SEED_BUYER_PW=YOUR_STRONG_PASSWORD
SEED_ELITE_PW=YOUR_STRONG_PASSWORD
SEED_PENDING_PW=YOUR_STRONG_PASSWORD
SEED_WEBHOST_PW=YOUR_STRONG_PASSWORD
